# ==========================================
# 🌐 CONFIGURACIÓN DEL SERVIDOR (Render / Local)
# ==========================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ==========================================
# 🗄️ BASE DE DATOS (Aiven + Prisma)
# ==========================================
# IMPORTANTE: Reemplaza esto con la URI que te da Aiven
DATABASE_URL="postgresql://usuario:contraseña@tu-host.aivencloud.com:puerto/defaultdb?sslmode=require"

# ==========================================
# 🧠 INTELIGENCIA ARTIFICIAL (Gemini)
# ==========================================
GEMINI_API_KEY="tu_api_key_de_google_ai_studio"
CRON_SECRET="una_contraseña_segura_para_el_cron_job"